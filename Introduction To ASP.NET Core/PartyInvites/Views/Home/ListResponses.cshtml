@model IEnumerable<GuestResponse>

@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="en">
<head>
    <meta name="viewport" content="width=device-width"/>
    <title>List Responses</title>
</head>
<body>
<div>
    <h2>Here is the list of people attending the party</h2>
</div>
<div>
    <table>
        <thead>
        <tr>
            <th>Name</th><th>Email</th><th>Phone</th>
        </tr>
        </thead>
        <tbody>
        @foreach (GuestResponse response in Model) {
            <tr>
                <td>@response.Name</td>
                <td>@response.Email</td>
                <td>@response.Phone</td>
            </tr>
        }
        </tbody>
    </table>
</div>
<div>
    <a asp-controller="Home" asp-action="Index">Index</a>
</div>
</body>
</html>