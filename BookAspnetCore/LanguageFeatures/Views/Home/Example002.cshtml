@using LanguageFeatures.Models
@model (IEnumerable<Product?>, decimal)
@{ Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Example 002</title>
</head>
<body>
    <h1>Extension methods</h1>

    <ul>
        @foreach (Product? product in Model.Item1) {
            if (product != null) {
                <li>@product.ToString()</li>
            }
        }
    </ul>

    <p>Total price = @Model.Item2.ToString("C2")</p>

    <a asp-controller="Home" asp-action="Index">Home page</a>
</body>
</html>