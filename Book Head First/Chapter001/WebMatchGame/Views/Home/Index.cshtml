@model IEnumerable<string>

@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="en">
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>Web Match Game</title>
        <link rel="stylesheet" href="~/lib/bootstrap/bootstrap.min.css"/>
        <link rel="stylesheet" href="~/css/style.css"/>
    </head>
    <body>
        <div class="container">
            <form asp-action="Index" method="post">
                <div class="row">
                    @foreach (string emoji in @Model)
                    {
                        <div class="col-3">
                            <button type="submit" name="emoji" value="@emoji" class="btn btn-outline-dark">
                                <h1>@emoji</h1>
                            </button>
                        </div>
                    }
                </div>
            </form>
        </div>
    </body>
</html>