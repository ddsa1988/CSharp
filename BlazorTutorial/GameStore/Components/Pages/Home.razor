@page "/"
@using GameStore.Models

<PageTitle>Game Catalog</PageTitle>

@if (_games?.Length > 0) {
    <table>
        <thead>
            <th>Id</th>
            <th>Name</th>
            <th>Genre</th>
            <th>Price</th>
            <th>Release date</th>
            <th></th>
        </thead>
        <tbody>
            @foreach(GameSummary game in _games)
            {
                <tr>
                    <td>@game.Id</td>
                    <td>@game.Name</td>
                    <td>@game.Genre</td>
                    <td>@game.Price</td>
                    <td>@game.ReleaseDate</td>
                </tr>
            }
        </tbody>
    </table>
}


@code{

    private readonly GameSummary[] _games = [
        new() { Id = 1, Name = "Street Fighter II", Genre = "Fight", Price = 19.9, ReleaseDate = new DateOnly(1992, 9, 27) },
        new(){Id = 2, Name = "Final Fantasy XIV", Genre = "Roleplaying", Price = 59.99, ReleaseDate = new DateOnly(2010,9,30)},
        new(){Id = 3, Name = "Fifa 23", Genre = "Sports", Price = 69.99, ReleaseDate = new DateOnly(2022,9,27)}
    ];
    
}