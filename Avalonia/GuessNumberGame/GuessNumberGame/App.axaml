<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GuessNumberGame.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/AppStyles.axaml" />
    </Application.Styles>
    <Application.Resources>
        <FontFamily x:Key="MontserratBold">/Assets/Fonts/Montserrat-Bold.ttf#Montserrat Bold</FontFamily>
        <Color x:Key="MainDarkColor">#222</Color>
        <Color x:Key="MainLightColor">#eee</Color>
        <Color x:Key="ButtonHoverColor">#ccc</Color>
        <Color x:Key="TexBoxDisableColor">#a9a9a9</Color>
        <SolidColorBrush x:Key="MainDarkColorBrush" Color="{StaticResource MainDarkColor}" />
        <SolidColorBrush x:Key="MainLightColorBrush" Color="{StaticResource MainLightColor}" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ButtonHoverColor}" />
        <SolidColorBrush x:Key="TextBoxDisableBrush" Color="{StaticResource TexBoxDisableColor}" />
    </Application.Resources>
</Application>