<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="GuessNumberGame.MainWindow"
        Title="GuessNumberGame"
        Width="600" Height="400">
    <StackPanel>
        <Grid ShowGridLines="True" RowDefinitions="100, 50,250">

            <Grid ShowGridLines="True" Grid.Row="0" ColumnDefinitions="150,300,150">
                <Button Grid.Column="0" VerticalAlignment="Top" Margin="10,10,0,0">Again?</Button>
                <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom">Guess My Number</TextBlock>
                <TextBlock Grid.Column="2" HorizontalAlignment="Center" Margin="0,10,0,0">(Between 1 and 20)</TextBlock>
            </Grid>

            <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">?</TextBlock>

            <Grid ShowGridLines="True" Grid.Row="2" ColumnDefinitions="300,300">
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBox Width="100" Margin="0,0,0,10" HorizontalContentAlignment="Center"></TextBox>
                    <Button Width="100" HorizontalContentAlignment="Center">Check!</Button>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,0,30">Start guessing...</TextBlock>
                    <TextBlock Margin="0,0,0,10">💯 Score: 20</TextBlock>
                    <TextBlock>🥇 High score: 0</TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1"></StackPanel>
            </Grid>

        </Grid>
    </StackPanel>
</Window>