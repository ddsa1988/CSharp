<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ExperimentWithControls.MainWindow"
        Title="Experiment With Controls"
        Width="800" Height="450">

    <Grid RowDefinitions="*,*,0.5*" ColumnDefinitions="*, *" ShowGridLines="True">

        <Grid RowDefinitions="*" ColumnDefinitions="*,*" Grid.Row="0" Grid.Column="0">

            <StackPanel Grid.Column="0" Margin="0 10 0 0" Width="150">
                <Label FontSize="18" Content="Enter a number" HorizontalAlignment="Center" />
                <TextBox FontSize="18" HorizontalContentAlignment="Center" TextWrapping="Wrap"
                         Text="0" TextChanged="NumberTextBox_OnTextChanged" />
            </StackPanel>

            <StackPanel Grid.Column="1">
            </StackPanel>

        </Grid>

        <TextBox Grid.Row="0" Grid.Column="1" Name="Number" FontSize="24" Width="120" HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 HorizontalContentAlignment="Center" TextWrapping="Wrap" Text="#" />

    </Grid>
</Window>