<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="BeehiveManagementSystem.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/AppStyles.axaml" />
    </Application.Styles>

    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryDarkColor" Color="#141720"></SolidColorBrush>
        <SolidColorBrush x:Key="PrimaryLightColor" Color="WhiteSmoke"></SolidColorBrush>

        <LinearGradientBrush x:Key="PrimaryDarkBrush" StartPoint="0,0" EndPoint="100,0">
            <GradientStop Offset="0" Color="#141720"></GradientStop>
            <GradientStop Offset="1" Color="#151e3e"></GradientStop>
        </LinearGradientBrush>

    </Application.Resources>
</Application>