<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="MatchGame.MainWindow"
        Title="Find all of the matching animals"
        Width="400" Height="500">

    <Grid Name="MainGrid" Classes="main-grid" RowDefinitions="*,*,*,*,*" ColumnDefinitions="*,*,*,*">

        <TextBlock Grid.Row="4" Grid.ColumnSpan="4" Name="TimeTextBlock" Classes="timer" Text="Elapsed Time"
                   PointerPressed="TimerPointerPressed" />
    </Grid>

</Window>