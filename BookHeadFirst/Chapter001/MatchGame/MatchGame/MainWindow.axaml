<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="MatchGame.MainWindow"
        Title="Find all of the matching animals"
        Width="400" Height="500">

    <Grid Name="MainGrid" Classes="main-grid" RowDefinitions="*,*,*,*,*" ColumnDefinitions="*,*,*,*">

        <Border Grid.Row="0" Grid.Column="0" Classes="text-block-border" />
        <Border Grid.Row="0" Grid.Column="1" Classes="text-block-border" />
        <Border Grid.Row="0" Grid.Column="2" Classes="text-block-border" />
        <Border Grid.Row="0" Grid.Column="3" Classes="text-block-border" />

        <Border Grid.Row="1" Grid.Column="0" Classes="text-block-border" />
        <Border Grid.Row="1" Grid.Column="1" Classes="text-block-border" />
        <Border Grid.Row="1" Grid.Column="2" Classes="text-block-border" />
        <Border Grid.Row="1" Grid.Column="3" Classes="text-block-border" />

        <Border Grid.Row="2" Grid.Column="0" Classes="text-block-border" />
        <Border Grid.Row="2" Grid.Column="1" Classes="text-block-border" />
        <Border Grid.Row="2" Grid.Column="2" Classes="text-block-border" />
        <Border Grid.Row="2" Grid.Column="3" Classes="text-block-border" />

        <Border Grid.Row="3" Grid.Column="0" Classes="text-block-border" />
        <Border Grid.Row="3" Grid.Column="1" Classes="text-block-border" />
        <Border Grid.Row="3" Grid.Column="2" Classes="text-block-border" />
        <Border Grid.Row="3" Grid.Column="3" Classes="text-block-border" />

        <TextBlock Grid.Row="0" Grid.Column="0" Name="TextBlock00" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="0" Grid.Column="1" Name="TextBlock01" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="0" Grid.Column="2" Name="TextBlock02" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="0" Grid.Column="3" Name="TextBlock03" Classes="text-block"
                   PointerPressed="TextBlockClicked" />

        <TextBlock Grid.Row="1" Grid.Column="0" Name="TextBlock10" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="1" Grid.Column="1" Name="TextBlock11" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="1" Grid.Column="2" Name="TextBlock12" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="1" Grid.Column="3" Name="TextBlock13" Classes="text-block"
                   PointerPressed="TextBlockClicked" />

        <TextBlock Grid.Row="2" Grid.Column="0" Name="TextBlock20" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="2" Grid.Column="1" Name="TextBlock21" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="2" Grid.Column="2" Name="TextBlock22" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="2" Grid.Column="3" Name="TextBlock23" Classes="text-block"
                   PointerPressed="TextBlockClicked" />

        <TextBlock Grid.Row="3" Grid.Column="0" Name="TextBlock30" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="3" Grid.Column="1" Name="TextBlock31" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="3" Grid.Column="2" Name="TextBlock32" Classes="text-block"
                   PointerPressed="TextBlockClicked" />
        <TextBlock Grid.Row="3" Grid.Column="3" Name="TextBlock33" Classes="text-block"
                   PointerPressed="TextBlockClicked" />

    </Grid>

</Window>