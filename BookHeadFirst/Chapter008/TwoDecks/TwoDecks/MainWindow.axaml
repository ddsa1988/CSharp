<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="TwoDecks.MainWindow"
        Title="Two Decks"
        Width="400" Height="450">

    <Grid Classes="grid-main" ColumnDefinitions="*,*" RowDefinitions="Auto,*,Auto,Auto">

        <Label Grid.Column="0" Grid.Row="0" Name="LabelDeck1" Classes="title" Content="Deck 1" />
        <ListBox Grid.Column="0" Grid.Row="1" Name="ListBoxDeck1" Classes="deck" />
        <Button Grid.Column="0" Grid.Row="2" Name="ShuffleLeftDeck" Classes="btn" Content="Shuffle"
                Click="Button_Shuffle" />
        <Button Grid.Column="0" Grid.Row="3" Name="ResetLeftDeck" Classes="btn" Content="Reset" Click="Button_Reset" />

        <Label Grid.Column="1" Grid.Row="0" Name="LabelDeck2" Classes="title" Content="Deck 1" />
        <ListBox Grid.Column="1" Grid.Row="1" Name="ListBoxDeck2" Classes="deck" />
        <Button Grid.Column="1" Grid.Row="2" Name="ClearRightDeck" Classes="btn" Content="Clear" Click="Button_Clear" />
        <Button Grid.Column="1" Grid.Row="3" Name="SortRightDeck" Classes="btn" Content="Sort" Click="Button_Sort" />

    </Grid>

</Window>