<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="PickCardUI.MainWindow"
        Title="Pick Card"
        Width="800" Height="450">

    <Grid Classes="main-grid" RowDefinitions="*,*" ColumnDefinitions="*,*">
        <StackPanel Classes="left-panel" Grid.Row="0" Grid.Column="0">

            <Label Classes="pick-cards-label" Content="How many cards should I pick?" />
            <Slider Classes="pick-cards-slider" Name="NumberOfCards" ValueChanged="NumberOfCards_OnValueChanged" />

            <StackPanel Classes="number-cards-panel">
                <Label Classes="number-cards-label" Content="Number of cards:" />
                <TextBlock Classes="number-cards-text" Name="Number" Text="1" />

            </StackPanel>
        </StackPanel>

        <Button Classes="pick-cards-button" Grid.Row="1" Grid.Column="0" Content="Pick some cards"
                Click="Button_OnClick" />

        <ListBox Classes="cards-picked-listbox" Name="ListOfCards" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"></ListBox>

    </Grid>

</Window>