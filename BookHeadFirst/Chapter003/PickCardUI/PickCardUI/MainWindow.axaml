<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="PickCardUI.MainWindow"
        Title="Pick Card"
        Width="800" Height="450">

    <Grid RowDefinitions="*,*" ColumnDefinitions="*,*" ShowGridLines="True">
        <StackPanel Grid.Row="0" Grid.Column="0" Width="350" Margin="0 10 0 0">
            <Label Content="How many cards should I pick?" HorizontalAlignment="Center" />
            <Slider Name="NumberOfCards" Minimum="1" Maximum="20" IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    TickFrequency="1" />
        </StackPanel>

        <Button Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Content="Pick some cards"
                PointerPressed="Button_OnPointerPressed" />

        <ListBox Name="ListOfCards" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Margin="10"></ListBox>

    </Grid>

</Window>