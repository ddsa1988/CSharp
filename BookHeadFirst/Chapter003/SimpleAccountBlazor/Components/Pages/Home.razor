@page "/"
@using SimpleAccountBlazor.Models
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<div class="container">
    <div class="row">
        <h1>Simple Account</h1>
    </div>
    <div class="row mt-5">
        <div class="col-sm-3">
            <h3>Name:</h3>
        </div>
        <div class="col-sm-3">
            <input type="text" disabled="disabled" value="@ManageAccount.Account.Name"/>
        </div>
        <div class="col-sm-3">
            <h3>Balance:</h3>
        </div>
        <div class="col-sm-3">
            <input type="text" disabled="disabled" value="@ManageAccount.Account.Balance.ToString("C2")"/>
        </div>
    </div>
    <div class="row mt-5">
        <div class="col-sm-4">
            <input type="number" @bind="ManageAccount.Amount"/>
        </div>
        <div class="col-sm-4">
            <button type="button" class="btn btn-primary" @onclick="() => ManageAccount.Deposit(ManageAccount.Amount)">
                Deposit
            </button>
        </div>
        <div class="col-sm-4">
            <button type="button" class="btn btn-warning" @onclick="() => ManageAccount.Withdraw(ManageAccount.Amount)">
                Withdraw
            </button>
        </div>
    </div>
</div>
