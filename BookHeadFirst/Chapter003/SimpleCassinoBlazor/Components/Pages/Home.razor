@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<div class="container">
    <div class="row">
        <h1>Simple Cassino</h1>
    </div>
    <div class="row">
        <p>Welcome to the cassino. The odds are 0.75</p>
    </div>
    <div class="row">
        <p>The player has 100 bucks</p>
    </div>
    <div class="row">
        <div class="col-sm-6">
            <span>How much do you like to bet:</span>
            <input type="number"/>
            <button type="button">Bet</button>
        </div>
    </div>
</div>