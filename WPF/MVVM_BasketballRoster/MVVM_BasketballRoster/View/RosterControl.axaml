<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:MVVM_BasketballRoster.ViewModel"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
             x:Class="MVVM_BasketballRoster.View.RosterControl"
             x:DataType="viewModel:RosterViewModel"
             Width="300" Height="400">

    <Border BorderThickness="2" BorderBrush="Blue" CornerRadius="6">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding TeamName}" />
            <TextBlock Text="Starting Players" />
            <ListBox ItemsSource="{Binding Starters}" />
            <TextBlock Text="Bench Players" />
            <ListBox ItemsSource="{Binding Bench}" />
        </StackPanel>
    </Border>

</UserControl>